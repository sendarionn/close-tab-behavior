{
  "manifest_version": 3,
  "name": "close-tab-behavior",
  "version": "1.0.0",
  "description": "アクティブなタブを閉じた後に、どのタブへ移動するかを選べます。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "タブを閉じた後の移動先",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
